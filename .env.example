# API local
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=gestionspa;Username=postgres;Password=postgres

# Frontend local (npm run dev)
VITE_API_URL=http://localhost:5000/api

# --- Backend CORS ---
# URLs del frontend separadas por coma (sin barra final)
FRONTEND_URL=http://localhost:5173,https://gestionspa.pages.dev,https://tudominio.com
# Orígenes extra (opcional, se suman a FRONTEND_URL)
CORS_ORIGINS=
# true = permite cualquier https://*.pages.dev (Cloudflare Pages)
CORS_ALLOW_PAGES_DEV=true

# --- Railway API ---
# DATABASE_URL=postgresql://user:pass@host:port/railway

# --- Cloudflare Pages (build) ---
# VITE_API_URL=https://tu-api.up.railway.app/api
